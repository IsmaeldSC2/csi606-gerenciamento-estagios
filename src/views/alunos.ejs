<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >

    <title>Alunos</title>

    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

<header>
    <h1>Alunos cadastrados</h1>
</header>

<main>

    <p>
        <a href="/alunos/novo">
            Cadastrar novo aluno
        </a>
    </p>

    <% if (alunos.length === 0) { %>

        <p>Nenhum aluno cadastrado.</p>

    <% } else { %>

        <table>
            <thead>
                <tr>
                    <th>Nome</th>
                    <th>E-mail</th>
                    <th>Curso</th>
                    <th>Ações</th>
                </tr>
            </thead>

            <tbody>

                <% alunos.forEach((aluno) => { %>

                    <tr>
                        <td>
                            <%= aluno.nome %>
                        </td>

                        <td>
                            <%= aluno.email %>
                        </td>

                        <td>
                            <%= aluno.curso %>
                        </td>

                        <td>
                            <form
                                action="/alunos/<%= aluno.id %>/excluir"
                                method="POST"
                                onsubmit="return confirm('Deseja realmente excluir este aluno?')"
                            >
                                <button type="submit">
                                    Excluir
                                </button>
                            </form>
                        </td>
                    </tr>

                <% }) %>

            </tbody>
        </table>

    <% } %>

    <p>
        <a href="/">
            Voltar para a página inicial
        </a>
    </p>

</main>

</body>
</html>