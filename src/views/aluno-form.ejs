<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >

    <title>Cadastrar aluno</title>

    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

<header>
    <h1>Cadastrar novo aluno</h1>
</header>

<main>

    <form action="/alunos" method="POST">

        <div>
            <label for="nome">
                Nome:
            </label>

            <input
                type="text"
                id="nome"
                name="nome"
                required
            >
        </div>

        <div>
            <label for="email">
                E-mail:
            </label>

            <input
                type="email"
                id="email"
                name="email"
                required
            >
        </div>

        <div>
            <label for="curso">
                Curso:
            </label>

            <input
                type="text"
                id="curso"
                name="curso"
                placeholder="Ex.: Sistemas de Informação"
                required
            >
        </div>

        <button type="submit">
            Cadastrar aluno
        </button>

    </form>

    <p>
        <a href="/alunos">
            Voltar para a lista de alunos
        </a>
    </p>

    <p>
        <a href="/">
            Voltar para a página inicial
        </a>
    </p>

</main>

</body>
</html>